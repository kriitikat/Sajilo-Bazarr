}
QPushButton#btnPrevPage:disabled, QPushButton#btnNextPage:disabled {
    background-color: #C8CDD4;
    color: #F4F6F9;
}
QTableWidget {
    background-color: #FFFFFF;
    border: 1px solid #DDE3EC;
    border-radius: 8px;
    gridline-color: #EEF1F6;
    selection-background-color: #E6F4EA;
