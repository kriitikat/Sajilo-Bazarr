              <string>Refresh</string>
             </property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>

        <!-- ── Summary cards ─────────────────────────────────────── -->
        <item>
         <layout class="QHBoxLayout" name="summaryRow">
          <property name="spacing"><number>16</number></property>
          <item>
           <widget class="QFrame" name="cardAssigned">
            <layout class="QVBoxLayout" name="cardAssignedLayout">
             <property name="spacing"><number>4</number></property>
             <property name="leftMargin"><number>12</number></property>
             <property name="topMargin"><number>12</number></property>
             <property name="rightMargin"><number>12</number></property>
             <property name="bottomMargin"><number>12</number></property>
             <item>
              <widget class="QLabel" name="lblAssignedTitle">
               <property name="text"><string>Assigned</string></property>
              </widget>
             </item>
             <item>
              <widget class="QLabel" name="lblAssignedValue">
               <property name="text"><string>0</string></property>
              </widget>
             </item>
            </layout>
           </widget>
          </item>
          <item>
           <widget class="QFrame" name="cardPending">
            <layout class="QVBoxLayout" name="cardPendingLayout">
             <property name="spacing"><number>4</number></property>
             <property name="leftMargin"><number>12</number></property>
             <property name="topMargin"><number>12</number></property>
             <property name="rightMargin"><number>12</number></property>
             <property name="bottomMargin"><number>12</number></property>
             <item>
              <widget class="QLabel" name="lblPendingTitle">
               <property name="text"><string>Pending</string></property>
              </widget>
             </item>
             <item>
              <widget class="QLabel" name="lblPendingValue">
               <property name="text"><string>0</string></property>
              </widget>
             </item>
            </layout>
           </widget>
          </item>
          <item>
           <widget class="QFrame" name="cardCompleted">
            <layout class="QVBoxLayout" name="cardCompletedLayout">
             <property name="spacing"><number>4</number></property>
             <property name="leftMargin"><number>12</number></property>
             <property name="topMargin"><number>12</number></property>
             <property name="rightMargin"><number>12</number></property>
             <property name="bottomMargin"><number>12</number></property>
             <item>
              <widget class="QLabel" name="lblCompletedTitle">
               <property name="text"><string>Completed</string></property>
              </widget>
             </item>
             <item>
              <widget class="QLabel" name="lblCompletedValue">
