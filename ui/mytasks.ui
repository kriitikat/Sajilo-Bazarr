             </item>
            </layout>
           </widget>
          </item>
         </layout>
        </item>

        <!-- ── Empty state (shown when the staff member has 0 tasks) ── -->
        <item>
         <widget class="QLabel" name="emptyStateLabel">
          <property name="text">
           <string>No tasks currently assigned by management.</string>
          </property>
          <property name="alignment">
           <set>Qt::AlignmentFlag::AlignCenter</set>
          </property>
          <property name="visible">
           <bool>false</bool>
          </property>
         </widget>
        </item>

        <!-- ── Dynamic task card list container ──────────────────── -->
        <!-- Left empty in Designer on purpose: MyTasks::loadTasksForStaff()
             populates taskCardsLayout with one card per task at runtime,
             since the number of cards depends on the DB query result and
             can't be fixed at design time. -->
        <item>
         <widget class="QWidget" name="taskCardsContainer" native="true">
          <layout class="QVBoxLayout" name="taskCardsLayout">
           <property name="spacing"><number>16</number></property>
           <property name="leftMargin"><number>0</number></property>
           <property name="topMargin"><number>0</number></property>
           <property name="rightMargin"><number>0</number></property>
           <property name="bottomMargin"><number>0</number></property>
          </layout>
         </widget>
        </item>

        <item>
         <spacer name="bottomSpacer">
          <property name="orientation"><enum>Qt::Orientation::Vertical</enum></property>
          <property name="sizeHint" stdset="0">
           <size><width>20</width><height>40</height></size>
          </property>
         </spacer>
        </item>
       </layout>
      </widget>
     </widget>
    </item>
   </layout>
  </widget>
  <widget class="QMenuBar" name="menubar">
