<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MyTasks</class>
 <widget class="QMainWindow" name="MyTasks">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>800</width>
    <height>900</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Inventory Management - My Assigned Tasks</string>
  </property>

  <!-- ═══════════════════════════════════════════════════════════════
       MASTER STYLESHEET — every color used anywhere in this module
       lives here, and ONLY here. mytasks.cpp never contains a hex
       color or a QSS string.

       - Static widgets (greeting banner, summary cards, empty state)
         are targeted by objectName, e.g. "#headerFrame".
       - The per-task cards are built at runtime in mytasks.cpp
         (count/content depend on the DB query, so Designer can't lay
         them out ahead of time). Each piece of a card is tagged with
         a "role" dynamic property from the .cpp and matched here,
         e.g. QPushButton[role="markCompleted"].
       ═══════════════════════════════════════════════════════════════ -->
  <property name="styleSheet">
   <string notr="true">/* ── Page background ─────────────────────────────────────── */
#centralwidget { background-color:#fbf3f5; }

/* ── Greeting banner (static) ────────────────────────────── */
#headerFrame { background-color:#660033; border-radius:8px; }
#greetingLabel { font-size:22px; font-weight:bold; color:#FDE68A; border:none; }
#btnBackToDashboard {
    background-color:transparent; color:#FDE68A; border:1px solid #FDE68A;
    border-radius:6px; padding:8px 16px; font-size:12px; font-weight:bold;
}
#btnBackToDashboard:hover { background-color:rgba(253,230,138,40); }
#btnRefresh {
    background-color:#FFFFFF; color:#660033; border:none;
    border-radius:6px; padding:8px 16px; font-size:12px; font-weight:bold;
}
#btnRefresh:hover { background-color:#fbe7ec; }

/* ── Summary cards (static) ──────────────────────────────── */
#cardAssigned { background-color:#FFFFFF; border:1px solid #f0dde1; border-radius:8px; }
#lblAssignedTitle { color:#660033; font-size:13px; font-weight:500; border:none; }
#lblAssignedValue { color:#660033; font-size:24px; font-weight:bold; border:none; }

#cardPending { background-color:#FFFFFF; border:1px solid #f0dde1; border-radius:8px; }
#lblPendingTitle { color:#9c7480; font-size:13px; font-weight:500; border:none; }
#lblPendingValue { color:#4a1626; font-size:24px; font-weight:bold; border:none; }

#cardCompleted { background-color:#F0FDF4; border:1px solid #f0dde1; border-radius:8px; }
#lblCompletedTitle { color:#15803D; font-size:13px; font-weight:500; border:none; }
#lblCompletedValue { color:#15803D; font-size:24px; font-weight:bold; border:none; }

/* ── Empty state (static) ────────────────────────────────── */
#emptyStateLabel { font-size:14px; color:#9c7480; border:none; }

/* ── Task cards (dynamic, role-driven) ───────────────────── */
QFrame[role="taskCard"] {
    background-color:#FFFFFF; border:1px solid #f0dde1; border-radius:10px;
}

/* Priority badges — same enable/disable/expire palette as staffperform.ui,
   so severity reads consistently across the whole theme. */
QLabel[role="priorityLow"] {
    background-color:#F0FDF4; color:#16a34a; border:none; border-radius:4px;
    padding:4px 10px; font-size:11px; font-weight:bold;
}
QLabel[role="priorityMedium"] {
    background-color:#FFFAF0; color:#d97706; border:none; border-radius:4px;
    padding:4px 10px; font-size:11px; font-weight:bold;
}
QLabel[role="priorityHigh"] {
    background-color:#FFF5F5; color:#8B0000; border:none; border-radius:4px;
    padding:4px 10px; font-size:11px; font-weight:bold;
}

QLabel[role="cardDue"]         { color:#9c7480; font-size:12px; font-weight:500; border:none; }
QLabel[role="cardTitle"]       { font-size:16px; font-weight:bold; color:#4a1626; border:none; }
QLabel[role="cardDescription"] { color:#4a1626; font-size:13px; border:none; }
QLabel[role="cardStatus"]      { color:#4a1626; font-size:12px; font-weight:bold; border:none; }

/* "Mark Completed" action button and its post-click, disabled state */
QPushButton[role="markCompleted"] {
    background-color:#660033; color:#FFFFFF; border:none; border-radius:6px;
    padding:6px 14px; font-size:12px; font-weight:bold;
}
QPushButton[role="markCompleted"]:hover   { background-color:#4A0F2B; }
QPushButton[role="markCompleted"]:pressed { background-color:#3A0A21; }

QPushButton[role="completedTag"] {
    background-color:#F0FDF4; color:#16a34a; border:1px solid #bbf0cc;
    border-radius:6px; padding:6px 14px; font-size:12px; font-weight:bold;
}
</string>
  </property>

  <widget class="QWidget" name="centralwidget">
   <layout class="QVBoxLayout" name="rootLayout">
    <property name="spacing"><number>0</number></property>
    <property name="leftMargin"><number>0</number></property>
    <property name="topMargin"><number>0</number></property>
    <property name="rightMargin"><number>0</number></property>
    <property name="bottomMargin"><number>0</number></property>
    <item>
     <widget class="QScrollArea" name="scrollArea">
      <property name="frameShape">
       <enum>QFrame::Shape::NoFrame</enum>
      </property>
      <property name="widgetResizable">
       <bool>true</bool>
      </property>
      <widget class="QWidget" name="scrollAreaWidgetContents">
       <property name="geometry">
        <rect><x>0</x><y>0</y><width>800</width><height>900</height></rect>
       </property>
       <layout class="QVBoxLayout" name="pageLayout">
        <property name="spacing"><number>20</number></property>
        <property name="leftMargin"><number>24</number></property>
        <property name="topMargin"><number>24</number></property>
        <property name="rightMargin"><number>24</number></property>
        <property name="bottomMargin"><number>24</number></property>

        <!-- ── Greeting banner ───────────────────────────────────── -->
        <item>
         <widget class="QFrame" name="headerFrame">
          <layout class="QHBoxLayout" name="headerRow">
           <property name="leftMargin"><number>16</number></property>
           <property name="topMargin"><number>16</number></property>
           <property name="rightMargin"><number>16</number></property>
           <property name="bottomMargin"><number>16</number></property>
           <item>
            <widget class="QLabel" name="greetingLabel">
             <property name="text">
              <string>Active Tasks</string>
             </property>
            </widget>
           </item>
           <item>
            <spacer name="headerSpacer">
             <property name="orientation"><enum>Qt::Orientation::Horizontal</enum></property>
             <property name="sizeHint" stdset="0">
              <size><width>40</width><height>20</height></size>
             </property>
            </spacer>
           </item>
           <item>
            <widget class="QPushButton" name="btnBackToDashboard">
             <property name="cursor">
              <cursorShape>PointingHandCursor</cursorShape>
             </property>
             <property name="text">
              <string>← Back to Dashboard</string>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QPushButton" name="btnRefresh">
