<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>Login</class>

 <widget class="QMainWindow" name="Login">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>420</width>
    <height>440</height>
   </rect>
  </property>

  <property name="minimumSize">
   <size>
    <width>420</width>
    <height>440</height>
   </size>
  </property>

  <property name="windowTitle">
   <string>Sajilo Bazar - Login</string>
  </property>

  <property name="styleSheet">
   <string notr="true">
    /* ── Window background ─────────────────────────────────────────── */
    QMainWindow, #centralwidget {
        background-color: #F4F6F8;
    }

    /* ── Title / subtitle ──────────────────────────────────────────── */
    QLabel#titleLabel {
        color: #1F2A44;
        font-size: 24px;
        font-weight: 600;
    }

    QLabel#subtitleLabel {
        color: #7A8699;
        font-size: 12px;
    }

    /* ── Status message (errors in red, success in green — color is
           toggled at runtime via a dynamic property, styled below) ───── */
    QLabel#statusLabel {
        font-size: 12px;
        min-height: 16px;
    }
    QLabel#statusLabel[status="error"] {
        color: #C0392B;
    }
    QLabel#statusLabel[status="success"] {
        color: #1E8449;
    }

    /* ── Input fields ──────────────────────────────────────────────── */
    QLineEdit {
        background-color: #FFFFFF;
        border: 1px solid #D8DEE6;
        border-radius: 8px;
        padding: 10px 12px;
        font-size: 13px;
        color: #1F2A44;
        selection-background-color: #4C6FFF;
    }
    QLineEdit:focus {
        border: 1px solid #4C6FFF;
    }
    QLineEdit:disabled {
        background-color: #EEF1F5;
        color: #A6AEBB;
    }

    /* ── Primary button (Log In) ──────────────────────────────────────── */
    QPushButton#loginButton {
        background-color: #4C6FFF;
        color: #FFFFFF;
        border: none;
        border-radius: 8px;
        padding: 11px 12px;
        font-size: 13px;
        font-weight: 600;
    }
    QPushButton#loginButton:hover {
        background-color: #3F5CE0;
    }
    QPushButton#loginButton:pressed {
        background-color: #3450C9;
    }
    QPushButton#loginButton:disabled {
        background-color: #AEB9E8;
    }

    /* ── Secondary button (Register) ──────────────────────────────────── */
    QPushButton#registerButton {
        background-color: transparent;
        color: #4C6FFF;
        border: none;
        padding: 8px;
        font-size: 12px;
        font-weight: 600;
    }
    QPushButton#registerButton:hover {
        color: #3450C9;
        text-decoration: underline;
    }
    QPushButton#registerButton:pressed {
        color: #26399C;
    }
   </string>
  </property>

  <widget class="QWidget" name="centralwidget">

   <layout class="QVBoxLayout" name="verticalLayout">
    <property name="leftMargin"><number>40</number></property>
    <property name="rightMargin"><number>40</number></property>
    <property name="topMargin"><number>36</number></property>
    <property name="bottomMargin"><number>28</number></property>
    <property name="spacing"><number>10</number></property>

    <item>
