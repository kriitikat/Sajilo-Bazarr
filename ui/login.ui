       <string>Password</string>
      </property>
      <property name="echoMode">
       <enum>QLineEdit::Password</enum>
      </property>
     </widget>
    </item>

    <item>
     <widget class="QLabel" name="statusLabel">
      <property name="text">
       <string/>
