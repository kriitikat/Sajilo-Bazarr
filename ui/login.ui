<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>Login</class>

 <widget class="QMainWindow" name="Login">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>960</width>
    <height>600</height>
   </rect>
  </property>

  <property name="minimumSize">
   <size>
    <width>860</width>
    <height>560</height>
   </size>
  </property>

  <property name="windowTitle">
   <string>Sajilo Bazar - Login</string>
  </property>

  <property name="styleSheet">
   <string notr="true">
    QMainWindow, QWidget#centralwidget {
        background-color: #F7F4F5;
    }

    /* ── Brand (left) panel — blurred, burgundy-tinted cart photo,
           loaded at runtime in Login::applyBrandingAssets() from
           resources/images/login_bg.jpg. The background-color below is
           only the fallback shown if that file can't be found on disk. */
    QFrame#brandPanel {
        background-color: #660033;
    }

    /* Frosted "glass" card that the logo + tagline sit on, so they stay
       readable no matter what part of the photo is behind them. A hairline
       border (barely-there burgundy tint) gives it a defined, premium edge
       instead of just floating on the photo. The drop shadow itself is
       applied at runtime in applyBrandingAssets() via
       QGraphicsDropShadowEffect. */
    QFrame#logoCard {
        background-color: rgba(255, 255, 255, 235);
        border: 1px solid rgba(102, 0, 51, 0.10);
        border-radius: 20px;
    }
    QLabel#brandLogo {
        background: transparent;
    }
    QLabel#brandTagline {
        background: transparent;
        color: #660033;
        font-size: 14px;
        font-weight: 600;
    }
    QLabel#brandFootnote {
        color: #F3E6EC;
        font-size: 12px;
        background: transparent;
    }

    /* ── Form (right) panel ─────────────────────────────────────── */
    QFrame#formPanel {
        background-color: #FFFFFF;
    }
    /* Thin border + radius so the card reads as a distinct, elevated
       surface rather than blending flat into the white form panel. */
    QFrame#card {
        background-color: #FFFFFF;
        border: 1px solid #F0E4E9;
        border-radius: 16px;
    }
    QLabel#titleLabel {
        color: #4A0F2B;
        font-size: 24px;
        font-weight: 700;
        background: transparent;
    }
    QLabel#subtitleLabel {
        color: #8A7580;
        font-size: 13px;
        padding-bottom: 6px;
        background: transparent;
    }
    QLabel#usernameLabel, QLabel#passwordLabel {
        color: #4A0F2B;
        font-size: 12px;
        font-weight: 600;
        background: transparent;
    }
    QLineEdit {
        border: 1px solid #E6DEE1;
        border-radius: 8px;
        padding: 8px 12px;
        font-size: 14px;
        background-color: #FFFFFF;
        color: #2C2C2C;
    }
    QLineEdit:focus {
        border: 1px solid #660033;
        background-color: #F3E6EC;
    }
    QLineEdit:disabled {
        background-color: #F2EDEF;
        color: #A69AA0;
    }
    QCheckBox {
        color: #6B5A63;
        font-size: 12px;
        background: transparent;
    }

    /* Status color is driven entirely by the "status" dynamic property,
       flipped from C++ via setStatus() — never a hardcoded color there. */
    QLabel#statusLabel {
        font-size: 12px;
        background: transparent;
    }
    QLabel#statusLabel[status="error"] {
        color: #8B0000;
    }
    QLabel#statusLabel[status="success"] {
        color: #1E7A47;
    }

    QPushButton#loginButton {
        background-color: #660033;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
    }
    QPushButton#loginButton:hover    { background-color: #4D0026; }
    QPushButton#loginButton:pressed  { background-color: #3A001C; }
    QPushButton#loginButton:disabled { background-color: #C9A9BA; }

    QPushButton#registerButton {
        background-color: #FFFFFF;
        color: #660033;
        border: 1px solid #E6DEE1;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
    }
    QPushButton#registerButton:hover { background-color: #F3E6EC; color: #4D0026; }
   </string>
  </property>

  <widget class="QWidget" name="centralwidget">

   <layout class="QHBoxLayout" name="mainLayout">
    <property name="spacing"><number>0</number></property>
    <property name="leftMargin"><number>0</number></property>
    <property name="topMargin"><number>0</number></property>
    <property name="rightMargin"><number>0</number></property>
    <property name="bottomMargin"><number>0</number></property>

    <!-- Left brand panel: blurred cart photo (login_bg.jpg) + frosted
         logo card carrying the real Sajilo Bazar logo. Both images are
         applied at runtime by Login::applyBrandingAssets() from
         resources/images/ — see login.cpp. -->
    <item>
     <widget class="QFrame" name="brandPanel">
      <property name="minimumSize"><size><width>380</width><height>0</height></size></property>
      <property name="maximumSize"><size><width>380</width><height>16777215</height></size></property>
      <layout class="QVBoxLayout" name="brandLayout">
       <property name="leftMargin"><number>40</number></property>
       <property name="topMargin"><number>0</number></property>
       <property name="rightMargin"><number>40</number></property>
       <property name="bottomMargin"><number>0</number></property>
       <property name="spacing"><number>18</number></property>

       <item>
        <spacer name="brandTopSpacer">
         <property name="orientation"><enum>Qt::Vertical</enum></property>
         <property name="sizeHint" stdset="0"><size><width>20</width><height>40</height></size></property>
        </spacer>
       </item>

       <!-- Frosted card: logo (real sajilobazar_logo.png, set via
            ui->brandLogo->setPixmap() in applyBrandingAssets()) + a
            single eye-catching tagline. Deliberately no bullet-point
            feature list — the logo/wordmark already carries the brand
            voice, so the copy here stays to one confident line. The
            "Sajilo Bazar" text below is only the placeholder shown if
            the logo file isn't found on disk. -->
       <item>
        <widget class="QFrame" name="logoCard">
         <layout class="QVBoxLayout" name="logoCardLayout">
          <property name="leftMargin"><number>16</number></property>
          <property name="topMargin"><number>20</number></property>
          <property name="rightMargin"><number>16</number></property>
          <property name="bottomMargin"><number>20</number></property>
          <property name="spacing"><number>10</number></property>

          <item>
           <widget class="QLabel" name="brandLogo">
            <property name="minimumSize"><size><width>0</width><height>212</height></size></property>
            <property name="alignment"><set>Qt::AlignCenter</set></property>
            <property name="text"><string>Sajilo Bazar</string></property>
            <property name="scaledContents"><bool>false</bool></property>
           </widget>
          </item>

          <item>
           <widget class="QLabel" name="brandTagline">
            <property name="text"><string>Stock Smarter. Serve Faster.</string></property>
            <property name="alignment"><set>Qt::AlignCenter</set></property>
            <property name="wordWrap"><bool>true</bool></property>
           </widget>
          </item>

         </layout>
        </widget>
       </item>

       <item>
        <spacer name="brandMidSpacer">
         <property name="orientation"><enum>Qt::Vertical</enum></property>
         <property name="sizeHint" stdset="0"><size><width>20</width><height>20</height></size></property>
        </spacer>
       </item>

       <item>
        <widget class="QLabel" name="brandFootnote">
         <property name="text"><string>Trusted by growing retailers, every day.</string></property>
         <property name="alignment"><set>Qt::AlignCenter</set></property>
         <property name="wordWrap"><bool>true</bool></property>
        </widget>
       </item>

       <item>
        <spacer name="brandBottomSpacer">
         <property name="orientation"><enum>Qt::Vertical</enum></property>
         <property name="sizeHint" stdset="0"><size><width>20</width><height>40</height></size></property>
        </spacer>
       </item>

      </layout>
     </widget>
    </item>

    <!-- Right form panel -->
    <item>
     <widget class="QFrame" name="formPanel">
      <layout class="QVBoxLayout" name="formOuterLayout">
       <property name="leftMargin"><number>0</number></property>
       <property name="topMargin"><number>0</number></property>
       <property name="rightMargin"><number>0</number></property>
       <property name="bottomMargin"><number>0</number></property>

       <item>
        <spacer name="formTopSpacer">
         <property name="orientation"><enum>Qt::Vertical</enum></property>
         <property name="sizeHint" stdset="0"><size><width>20</width><height>40</height></size></property>
        </spacer>
       </item>

       <item>
        <layout class="QHBoxLayout" name="formCenterLayout">
         <item>
          <spacer name="formLeftSpacer">
           <property name="orientation"><enum>Qt::Horizontal</enum></property>
           <property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property>
          </spacer>
         </item>

         <item>
          <widget class="QFrame" name="card">
           <property name="minimumSize"><size><width>360</width><height>0</height></size></property>
           <property name="maximumSize"><size><width>360</width><height>16777215</height></size></property>
           <layout class="QVBoxLayout" name="cardLayout">
            <property name="spacing"><number>10</number></property>
            <property name="leftMargin"><number>36</number></property>
            <property name="topMargin"><number>36</number></property>
            <property name="rightMargin"><number>36</number></property>
            <property name="bottomMargin"><number>32</number></property>

            <item>
             <widget class="QLabel" name="titleLabel">
              <property name="text"><string>Welcome back</string></property>
             </widget>
            </item>

            <item>
             <widget class="QLabel" name="subtitleLabel">
              <property name="text"><string>Sign in to continue to your dashboard</string></property>
              <property name="wordWrap"><bool>true</bool></property>
             </widget>
            </item>

            <item>
             <widget class="QLabel" name="usernameLabel">
              <property name="text"><string>Username</string></property>
             </widget>
            </item>
            <item>
             <widget class="QLineEdit" name="usernameEdit">
              <property name="minimumSize"><size><width>0</width><height>40</height></size></property>
              <property name="placeholderText"><string>Enter your username</string></property>
             </widget>
            </item>

            <item>
             <widget class="QLabel" name="passwordLabel">
              <property name="text"><string>Password</string></property>
             </widget>
            </item>
            <item>
             <widget class="QLineEdit" name="passwordEdit">
              <property name="minimumSize"><size><width>0</width><height>40</height></size></property>
              <property name="placeholderText"><string>Enter your password</string></property>
              <property name="echoMode"><enum>QLineEdit::Password</enum></property>
             </widget>
            </item>

            <item>
             <widget class="QLabel" name="statusLabel">
              <property name="text"><string/></property>
              <property name="wordWrap"><bool>true</bool></property>
              <property name="minimumSize"><size><width>0</width><height>18</height></size></property>
             </widget>
            </item>

            <item>
             <widget class="QPushButton" name="loginButton">
              <property name="minimumSize"><size><width>0</width><height>42</height></size></property>
              <property name="cursor"><cursorShape>PointingHandCursor</cursorShape></property>
              <property name="text"><string>Log In</string></property>
              <property name="default"><bool>true</bool></property>
             </widget>
            </item>

            <item>
             <widget class="QPushButton" name="registerButton">
              <property name="minimumSize"><size><width>0</width><height>38</height></size></property>
              <property name="cursor"><cursorShape>PointingHandCursor</cursorShape></property>
              <property name="text"><string>Create a new account</string></property>
             </widget>
            </item>

           </layout>
          </widget>
         </item>

         <item>
          <spacer name="formRightSpacer">
           <property name="orientation"><enum>Qt::Horizontal</enum></property>
           <property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property>
          </spacer>
         </item>
        </layout>
       </item>

       <item>
        <spacer name="formBottomSpacer">
         <property name="orientation"><enum>Qt::Vertical</enum></property>
         <property name="sizeHint" stdset="0"><size><width>20</width><height>40</height></size></property>
        </spacer>
       </item>

      </layout>
     </widget>
    </item>

   </layout>
  </widget>

  <widget class="QMenuBar" name="menubar"/>
  <widget class="QStatusBar" name="statusbar"/>

 </widget>
</ui>
