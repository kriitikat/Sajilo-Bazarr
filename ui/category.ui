  <property name="styleSheet">
   <string notr="true">QWidget {
    background-color: #fbf3f5;
    font-family: 'Segoe UI';
}

/* ── Back to Dashboard (shared convention with staffperform.ui) ────────── */
QPushButton#backToDashboardBtn {
    background-color: transparent;
    border: 1.5px solid #660033;
    border-radius: 10px;
    padding: 7px 16px;
    color: #660033;
    font-weight: bold;
    font-size: 11px;
}
QPushButton#backToDashboardBtn:hover {
    background-color: #660033;
    color: white;
}

/* ── Add Category (unique top-level action button) ──────────────────────
   Styled the same way staffperform.ui styles its unique refreshBtn: solid
   maroon pill, by object name rather than a dynamic property, since there
   is only ever one of these on the page. */
QPushButton#addCategoryBtn {
    background-color: #660033;
    border: none;
    padding: 8px 16px;
    color: white;
    font-weight: bold;
    border-radius: 10px;
    font-size: 11px;
}
QPushButton#addCategoryBtn:hover {
    background-color: #4d0026;
}
QPushButton#addCategoryBtn:pressed {
    background-color: #38001b;
}

/* ── Per-row ACTIONS button styling ───────────────────────────────────────
   category.cpp's buildActionsWidget-equivalent code (inside
   loadCategoriesTable) only sets each QPushButton's "actionRole" dynamic
   property (edit / delete); all color/hover/radius styling lives here -
   same convention as staffperform.ui's disable/enable/expire/unexpire
   buttons, so category.cpp never touches presentation directly.
   "edit" reuses the same teal used for staffperform's "unexpire" (a
   neutral, non-destructive action); "delete" reuses the same dark red
   used for staffperform's "expire" (a destructive/permanent action). */
QPushButton[actionRole="edit"] {
    background-color: #0891b2;
    border: none;
    border-radius: 6px;
    padding: 4px 10px;
    color: white;
    font-weight: bold;
    font-size: 11px;
}
QPushButton[actionRole="edit"]:hover {
    background-color: #0e7490;
}

QPushButton[actionRole="delete"] {
    background-color: #8B0000;
    border: none;
    border-radius: 6px;
    padding: 4px 10px;
    color: white;
    font-weight: bold;
    font-size: 11px;
}
QPushButton[actionRole="delete"]:hover {
    background-color: #660000;
}</string>
