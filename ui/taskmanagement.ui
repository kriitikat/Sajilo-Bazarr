     <!-- ── Assigned tasks table panel ───────────────────────────── -->
     <item>
      <widget class="QFrame" name="taskTablePanel">
       <layout class="QVBoxLayout" name="taskTablePanelLayout">
        <property name="leftMargin"><number>16</number></property>
        <property name="topMargin"><number>16</number></property>
