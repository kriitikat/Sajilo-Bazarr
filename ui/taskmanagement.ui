        <property name="bottomMargin"><number>16</number></property>
        <property name="spacing"><number>12</number></property>

        <item>
         <widget class="QLabel" name="tableTitleLabel">
          <property name="text"><string>ASSIGNED TASKS DATABASE RECORD</string></property>
          <property name="alignment"><set>Qt::AlignCenter</set></property>
         </widget>
        </item>

        <item>
         <widget class="QTableWidget" name="assignedTasksTable">
          <property name="alternatingRowColors"><bool>true</bool></property>
          <property name="selectionMode"><enum>QAbstractItemView::SingleSelection</enum></property>
          <property name="selectionBehavior"><enum>QAbstractItemView::SelectRows</enum></property>
          <property name="editTriggers"><set>QAbstractItemView::NoEditTriggers</set></property>
          <column><property name="text"><string>ID</string></property></column>
          <column><property name="text"><string>Staff Name</string></property></column>
          <column><property name="text"><string>Total Task</string></property></column>
          <column><property name="text"><string>Pending Task</string></property></column>
          <column><property name="text"><string>Completed Task</string></property></column>
          <column><property name="text"><string>Status</string></property></column>
          <column><property name="text"><string>Login Time</string></property></column>
          <column><property name="text"><string>Action</string></property></column>
