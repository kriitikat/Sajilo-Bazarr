<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>TaskManagement</class>
 <widget class="QMainWindow" name="TaskManagement">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>950</width>
    <height>980</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Inventory Management - Task Management</string>
  </property>

  <!-- ═══════════════════════════════════════════════════════════════
       MASTER STYLESHEET — every color, font weight, border, radius
       and hover/pressed/focus state for this module lives here, and
       ONLY here. taskmanagement.cpp never contains a hex color or a
       QSS string.

       Two targeting strategies are used:

       1) STATIC widgets built by Designer (the summary panel, the
          table, its header, the metric labels) are targeted by
          objectName, e.g. "#assignedTasksTable".

       2) DYNAMIC widgets built at runtime in taskmanagement.cpp — the
          Add Task / View Task dialogs, task-detail cards, priority
          badges, stat chips — can't have an objectName wired up in
          Designer because they're constructed fresh every time a
          dialog opens. Instead, taskmanagement.cpp tags each one with
          a dynamic "role" property (setProperty("role", "primary"),
          etc.) and this stylesheet matches on that, e.g.
          "QPushButton[role=\"primary\"]".

       Because taskmanagement.cpp copies this exact stylesheet onto
       every QDialog it builds (dialog.setStyleSheet(this->styleSheet())),
       the role selectors below apply inside those dialogs too, even
       though a QDialog is its own top-level window and wouldn't
       otherwise inherit the main window's stylesheet.
       ═══════════════════════════════════════════════════════════════ -->
  <property name="styleSheet">
   <string notr="true">/* ── Page / dialog background ─────────────────────────── */
#scrollAreaWidgetContents { background-color:#F7F4F5; }
QDialog { background-color:#F7F4F5; }

/* ── Summary panel + task table panel (static) ────────────── */
#summaryPanel, #tablePanel {
    background-color:#FFFFFF; border:1px solid #E6DEE1; border-radius:10px;
}
#lblOverviewTitle, #lblTableTitle {
    font-size:14px; font-weight:bold; color:#660033; letter-spacing:0.5px; border:none;
}
#searchBox {
    background-color:#FFFFFF; border:1px solid #E6DEE1; color:#2C2C2C;
    border-radius:6px; padding:6px; font-size:13px;
}
#searchBox:focus { border:1px solid #660033; }

#totalTasksLabel { font-size:13px; font-weight:bold; color:#660033; border:none; }
#pendingLabel    { font-size:13px; font-weight:bold; color:#B8790F; border:none; }
#inProgressLabel { font-size:13px; font-weight:bold; color:#A64D6E; border:none; }
#completedLabel  { font-size:13px; font-weight:bold; color:#7A4A5E; border:none; }

/* ── Task table (static) ──────────────────────────────────── */
#assignedTasksTable {
    background-color:#FFFFFF; border:none; gridline-color:#F5EEF0; outline:none;
}
#assignedTasksTable::item          { padding:6px; color:#2C2C2C; }
#assignedTasksTable::item:selected { background-color:#F3E6EC; color:#2C2C2C; }
#assignedTasksTable::item:hover    { background-color:#FBF7F8; }
#assignedTasksTable QHeaderView::section {
    background-color:#660033; color:#FFFFFF; font-weight:bold; border:none; padding:6px;
}

/* ── Panels &amp; containers (dynamic dialogs, role-driven) ──── */
QFrame[role="panel"] {
    background-color:#FFFFFF; border:1px solid #E6DEE1; border-radius:10px;
}
QFrame[role="taskCard"] {
    background-color:#F7F4F5; border:1px solid #E6DEE1; border-radius:8px;
}
QFrame[role="divider"] { color:#E6DEE1; }
QScrollArea[role="transparentScroll"] { background:transparent; border:none; }

/* ── Titles / labels (role-driven) ────────────────────────── */
QLabel[role="panelTitle"] {
    font-size:14px; font-weight:bold; color:#660033; letter-spacing:0.5px; border:none;
}
QLabel[role="sectionHeading"] {
    color:#660033; font-size:12px; font-weight:bold; letter-spacing:0.5px; border:none;
}
QLabel[role="fieldLabel"]      { font-weight:600; color:#4A0F2B; border:none; }
QLabel[role="valueLabel"]      { color:#2C2C2C; font-size:13px; border:none; }
QLabel[role="mutedNote"]       { color:#8A7580; font-size:12px; border:none; }
QLabel[role="cardTitle"]       { color:#2C2C2C; font-size:13px; font-weight:bold; border:none; }
QLabel[role="cardDescription"] { color:#6B5A63; font-size:12px; border:none; }
QLabel[role="cardMeta"]        { color:#8A7580; font-size:11px; border:none; }

/* Priority badges (Low / Medium / High) */
QLabel[role="priorityLow"] {
    background-color:#E9F9EF; color:#38A169; border:none; border-radius:8px;
    padding:2px 10px; font-size:11px; font-weight:bold;
}
QLabel[role="priorityMedium"] {
    background-color:#FFF3E0; color:#DD6B20; border:none; border-radius:8px;
    padding:2px 10px; font-size:11px; font-weight:bold;
}
QLabel[role="priorityHigh"] {
    background-color:#FDECEC; color:#E53E3E; border:none; border-radius:8px;
    padding:2px 10px; font-size:11px; font-weight:bold;
}

/* Stat chips (TOTAL / PENDING / COMPLETED) */
QFrame[role="statChipTotal"]     { background-color:#F3E6EC; border:none; border-radius:6px; }
QFrame[role="statChipPending"]   { background-color:#FFF3E0; border:none; border-radius:6px; }
QFrame[role="statChipCompleted"] { background-color:#E9F9EF; border:none; border-radius:6px; }

QLabel[role="statChipLabelTotal"]     { color:#660033; font-size:10px; font-weight:bold; border:none; }
QLabel[role="statChipLabelPending"]   { color:#DD6B20; font-size:10px; font-weight:bold; border:none; }
QLabel[role="statChipLabelCompleted"] { color:#38A169; font-size:10px; font-weight:bold; border:none; }

QLabel[role="statChipValueTotal"]     { color:#660033; font-size:16px; font-weight:bold; border:none; }
QLabel[role="statChipValuePending"]   { color:#DD6B20; font-size:16px; font-weight:bold; border:none; }
QLabel[role="statChipValueCompleted"] { color:#38A169; font-size:16px; font-weight:bold; border:none; }

/* ── Inputs (role-driven) ──────────────────────────────────── */
QWidget[role="inputField"] {
    background-color:#FFFFFF; border:1px solid #E6DEE1; color:#2C2C2C;
    border-radius:6px; padding:6px; font-size:13px; outline:none;
}
QWidget[role="inputField"]:focus { border:1px solid #660033; outline:none; }
QComboBox[role="inputField"] QAbstractItemView {
    color:#2C2C2C; background-color:#FFFFFF; outline:none;
    selection-background-color:#F3E6EC; selection-color:#4A0F2B;
}
QComboBox[role="inputField"] QAbstractItemView::item:hover {
    background-color:#F3E6EC; color:#4A0F2B;
}

/* ── Buttons (role-driven) ─────────────────────────────────── */
QPushButton[role="primary"] {
    background-color:#660033; color:#FFFFFF; border:none; border-radius:6px;
    padding:8px 20px; font-weight:bold; font-size:13px; outline:none;
}
QPushButton[role="primary"]:hover    { background-color:#4A0F2B; }
QPushButton[role="primary"]:pressed  { background-color:#3A0A21; }
QPushButton[role="primary"]:focus    { outline:none; border:none; }

QPushButton[role="secondary"] {
    background-color:#FFFFFF; color:#8A7580; border:1px solid #E6DEE1; border-radius:6px;
    padding:8px 18px; font-size:13px; font-weight:500; outline:none;
}
QPushButton[role="secondary"]:hover   { background-color:#F7F4F5; border-color:#A64D6E; }
QPushButton[role="secondary"]:pressed { background-color:#F3E6EC; }
QPushButton[role="secondary"]:focus   { outline:none; }

/* "Add Task" picks up the garnet color, "View Task" the amber color —
   intentionally matched to staffperform.ui's expire/disable palette. */
QPushButton[role="addTask"] {
    background-color:#8B0000; color:white; border:none; border-radius:6px;
    padding:4px 10px; font-size:11px; font-weight:bold; outline:none;
}
QPushButton[role="addTask"]:hover   { background-color:#660000; }
QPushButton[role="addTask"]:pressed { background-color:#4d0000; }
QPushButton[role="addTask"]:focus   { outline:none; }

QPushButton[role="viewTask"] {
    background-color:#d97706; color:white; border:none; border-radius:6px;
    padding:4px 10px; font-size:11px; font-weight:bold; outline:none;
}
QPushButton[role="viewTask"]:hover   { background-color:#b45309; }
QPushButton[role="viewTask"]:pressed { background-color:#92400e; }
QPushButton[role="viewTask"]:focus   { outline:none; }
</string>
  </property>

