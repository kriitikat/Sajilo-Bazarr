<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>TaskManagement</class>

 <widget class="QMainWindow" name="TaskManagement">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>980</width>
    <height>1080</height>
   </rect>
  </property>

  <property name="windowTitle">
   <string>Inventory Management - Task Management</string>
  </property>

  <property name="styleSheet">
   <string notr="true">
    QMainWindow, QWidget#scrollAreaWidgetContents {
        background-color: #F8FAFC;
    }

    /* ── Header bar ─────────────────────────────────────────────── */
    QFrame#headerBar {
        background-color: #2D4A7A;
        border-radius: 10px;
    }
    QLabel#headerTitleLabel {
        color: #FFFFFF;
        font-size: 20px;
        font-weight: 700;
    }
    QLabel#headerSubtitleLabel {
        color: #C7D6EC;
        font-size: 12px;
    }

    /* ── Generic white panel used by every section below the header ─ */
    QFrame#summaryPanel, QFrame#attendancePanel, QFrame#taskTablePanel {
        background-color: #FFFFFF;
        border: 1px solid #E2E8F0;
        border-radius: 10px;
    }
    QLabel#summaryTitleLabel, QLabel#attendanceTitleLabel, QLabel#tableTitleLabel {
        font-size: 14px;
        font-weight: 700;
        color: #2D4A7A;
        letter-spacing: 0.5px;
        border: none;
    }

    /* ── Summary metric cards ───────────────────────────────────── */
    QFrame#totalTasksCard  { background-color: #EBF2FF; border-radius: 8px; }
    QFrame#pendingCard     { background-color: #FFF3E0; border-radius: 8px; }
    QFrame#inProgressCard  { background-color: #EBF8FF; border-radius: 8px; }
    QFrame#completedCard   { background-color: #E9F9EF; border-radius: 8px; }

    QLabel#totalTasksLabel { color: #2D4A7A; font-size: 16px; font-weight: 700; border: none; }
    QLabel#pendingLabel    { color: #DD6B20; font-size: 16px; font-weight: 700; border: none; }
    QLabel#inProgressLabel { color: #3182CE; font-size: 16px; font-weight: 700; border: none; }
    QLabel#completedLabel  { color: #38A169; font-size: 16px; font-weight: 700; border: none; }

    /* ── Search box ──────────────────────────────────────────────── */
    QLineEdit#searchBox {
        background-color: #FFFFFF;
        border: 1px solid #CBD5E0;
        color: #000000;
        border-radius: 6px;
        padding: 6px;
        font-size: 13px;
    }
    QLineEdit#searchBox:focus { border: 1px solid #2D4A7A; }

    /* ── Attendance panel ────────────────────────────────────────── */
    QLabel#onlineCountLabel {
        background-color: #E9F9EF;
        color: #38A169;
        border: none;
        border-radius: 8px;
        padding: 2px 10px;
        font-size: 11px;
        font-weight: 700;
    }
    QWidget#attendanceCardsContainer {
        background: transparent;
    }

    /* ── Assigned tasks table ────────────────────────────────────── */
    QTableWidget#assignedTasksTable {
        background-color: #FFFFFF;
        border: none;
        gridline-color: #EDF2F7;
    }
    QTableWidget#assignedTasksTable::item { padding: 6px; color: #000000; }
    QTableWidget#assignedTasksTable::item:selected {
        background-color: #EBF2FF; color: #000000;
    }
    QTableWidget#assignedTasksTable QHeaderView::section {
        background-color: #2D4A7A;
        color: #FFFFFF;
        font-weight: 700;
        border: none;
        padding: 6px;
    }
   </string>
  </property>

  <widget class="QScrollArea" name="centralwidget">
   <property name="widgetResizable"><bool>true</bool></property>
   <property name="frameShape"><enum>QFrame::NoFrame</enum></property>

   <widget class="QWidget" name="scrollAreaWidgetContents">
    <property name="geometry"><rect><x>0</x><y>0</y><width>932</width><height>1032</height></rect></property>

    <layout class="QVBoxLayout" name="mainLayout">
     <property name="leftMargin"><number>24</number></property>
     <property name="topMargin"><number>24</number></property>
     <property name="rightMargin"><number>24</number></property>
     <property name="bottomMargin"><number>24</number></property>
     <property name="spacing"><number>20</number></property>

     <!-- ── Header bar ───────────────────────────────────────────── -->
     <item>
      <widget class="QFrame" name="headerBar">
       <layout class="QVBoxLayout" name="headerLayout">
        <property name="leftMargin"><number>20</number></property>
        <property name="topMargin"><number>16</number></property>
        <property name="rightMargin"><number>20</number></property>
        <property name="bottomMargin"><number>16</number></property>
