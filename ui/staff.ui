   <string notr="true">QWidget {
    background-color: #F7F4F5;
    font-family: 'Segoe UI';
}

/* ── Per-row ACTIONS button styling ───────────────────────────────────────
   Buttons in staff.cpp's buildActionsWidget() only set a QPushButton's
   &quot;actionRole&quot; dynamic property (edit / disable / enable / expire /
   unexpire); all color/hover/font/radius styling lives here so staff.cpp
   never touches presentation. */
QPushButton[actionRole=&quot;edit&quot;] {
    background-color: #7A4A5E;
    border: none;
    border-radius: 6px;
    padding: 4px 10px;
    color: white;
    font-weight: bold;
    font-size: 11px;
}
QPushButton[actionRole=&quot;edit&quot;]:hover {
    background-color: #5C3648;
}

QPushButton[actionRole=&quot;disable&quot;] {
    background-color: #B8790F;
    border: none;
    border-radius: 6px;
    padding: 4px 10px;
    color: white;
    font-weight: bold;
    font-size: 11px;
}
QPushButton[actionRole=&quot;disable&quot;]:hover {
    background-color: #96620C;
}

QPushButton[actionRole=&quot;enable&quot;] {
    background-color: #1E7A47;
    border: none;
    border-radius: 6px;
    padding: 4px 10px;
    color: white;
    font-weight: bold;
    font-size: 11px;
}
QPushButton[actionRole=&quot;enable&quot;]:hover {
    background-color: #175C36;
}

QPushButton[actionRole=&quot;expire&quot;] {
    background-color: #8B0000;
    border: none;
    border-radius: 6px;
    padding: 4px 10px;
    color: white;
    font-weight: bold;
    font-size: 11px;
}
QPushButton[actionRole=&quot;expire&quot;]:hover {
    background-color: #6B0000;
}

QPushButton[actionRole=&quot;unexpire&quot;] {
    background-color: #A64D6E;
    border: none;
    border-radius: 6px;
    padding: 4px 10px;
    color: white;
    font-weight: bold;
    font-size: 11px;
}
QPushButton[actionRole=&quot;unexpire&quot;]:hover {
    background-color: #7D3A54;
}</string>
