<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>Register</class>

 <widget class="QMainWindow" name="Register">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>480</width>
    <height>760</height>
   </rect>
  </property>

  <property name="minimumSize">
   <size>
    <width>440</width>
    <height>640</height>
   </size>
  </property>

  <property name="windowTitle">
   <string>Sajilo Bazar - Register</string>
  </property>

  <property name="styleSheet">
   <string notr="true">
    /* ── Base / layout — same Burgundy/Garnet palette as login.ui ────── */
    QMainWindow, QWidget#centralwidget, QWidget#scrollAreaContents {
        background-color: #F7F4F5;
    }
    QFrame#topBar {
        background-color: #FFFFFF;
        border-bottom: 1px solid #E6DEE1;
    }
    QPushButton#backToLoginButton {
        background-color: transparent;
        color: #660033;
        border: none;
        font-size: 13px;
        font-weight: 600;
        text-align: left;
    }
    QPushButton#backToLoginButton:hover { color: #4D0026; }

    QLabel#titleLabel {
        color: #4A0F2B;
        font-size: 22px;
        font-weight: 700;
        padding-top: 6px;
        background: transparent;
    }
    QLabel#subtitleLabel {
        color: #8A7580;
        font-size: 12px;
        padding-bottom: 4px;
        background: transparent;
    }

    /* Cards read as distinct, elevated surfaces — same hairline-border
       treatment as QFrame#card in login.ui — rather than the old flat
       drop-shadow-less blue-bordered boxes. */
    QGroupBox {
        background-color: #FFFFFF;
        border: 1px solid #F0E4E9;
        border-radius: 12px;
        margin-top: 12px;
        padding: 14px 12px 12px 12px;
        font-size: 12px;
        font-weight: 700;
        color: #4A0F2B;
    }
    QGroupBox::title {
        subcontrol-origin: margin;
        left: 10px;
        padding: 0 6px;
    }

    QLabel#roleLabel, QLabel#usernameLabel {
        color: #4A0F2B;
        font-size: 12px;
        font-weight: 600;
        padding-top: 4px;
        background: transparent;
    }

    QPushButton#regenerateUsernameButton {
        background-color: #FFFFFF;
        color: #660033;
        border: 1px solid #E6DEE1;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 600;
    }
    QPushButton#regenerateUsernameButton:hover { background-color: #F3E6EC; }
    QPushButton#regenerateUsernameButton:disabled { color: #C9A9BA; }

    QLineEdit, QComboBox {
        border: 1px solid #E6DEE1;
        border-radius: 8px;
        padding: 8px 12px;
        font-size: 14px;
        background-color: #FFFFFF;
        color: #2C2C2C;
    }
    QLineEdit:focus, QComboBox:focus {
        border: 1px solid #660033;
        background-color: #F3E6EC;
    }
    QLineEdit:read-only {
        background-color: #F2EDEF;
        color: #A69AA0;
    }
    QComboBox::drop-down {
        border: none;
        width: 24px;
    }

    QPushButton#submitButton {
        background-color: #660033;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
    }
    QPushButton#submitButton:hover    { background-color: #4D0026; }
    QPushButton#submitButton:pressed  { background-color: #3A001C; }
    QPushButton#submitButton:disabled { background-color: #C9A9BA; }

    /* ── Hint labels (email/phone/username/password) ────────────────────
       Default = neutral mauve-grey (matches login's muted tone). Runtime-
       only change is the "state" dynamic property, flipped from C++ via
       setLabelState(); every color for every state lives right here. ── */
    QLabel#emailHintLabel, QLabel#phoneHintLabel,
    QLabel#usernameHintLabel, QLabel#passwordHintLabel {
        font-size: 11px;
        color: #A69AA0;
        padding-left: 2px;
        background: transparent;
    }
    QLabel#emailHintLabel[state="success"],
    QLabel#phoneHintLabel[state="success"],
    QLabel#usernameHintLabel[state="success"],
    QLabel#passwordHintLabel[state="success"] {
        color: #1E7A47;
    }
    QLabel#emailHintLabel[state="error"],
    QLabel#phoneHintLabel[state="error"],
    QLabel#usernameHintLabel[state="error"],
    QLabel#passwordHintLabel[state="error"] {
        color: #8B0000;
    }
    /* Password strength has two extra in-between states the other hints
       don't use. Kept out of blue entirely to stay inside the burgundy/
       garnet/gold family. */
    QLabel#passwordHintLabel[state="warning"] { color: #B8790F; }
    QLabel#passwordHintLabel[state="info"]    { color: #7A4A5E; }

    /* ── Status label (bottom banner) ────────────────────────────────── */
    QLabel#statusLabel {
        font-size: 12px;
        padding-top: 4px;
        background: transparent;
    }
    QLabel#statusLabel[state="error"]   { color: #8B0000; }
    QLabel#statusLabel[state="success"] { color: #1E7A47; }

    /* ── Password strength bar ───────────────────────────────────────────
       Default (empty "strength" property) = neutral track, no fill color
       override needed since value is 0. Each state below recolors the
       chunk only. A warm gradient — garnet → gold → rose → green — reads
       as "weak to strong" without reaching for blue. ───────────────────── */
    QProgressBar#passwordStrengthBar {
        border: none;
        border-radius: 3px;
        background-color: #F2EDEF;
    }
    QProgressBar#passwordStrengthBar::chunk {
        border-radius: 3px;
        background-color: #F2EDEF;
    }
    QProgressBar#passwordStrengthBar[strength="weak"]::chunk   { background-color: #8B0000; }
    QProgressBar#passwordStrengthBar[strength="fair"]::chunk   { background-color: #B8790F; }
    QProgressBar#passwordStrengthBar[strength="good"]::chunk   { background-color: #A64D6E; }
    QProgressBar#passwordStrengthBar[strength="strong"]::chunk { background-color: #1E7A47; }
   </string>
  </property>

  <widget class="QWidget" name="centralwidget">

   <layout class="QVBoxLayout" name="outerLayout">
    <property name="leftMargin"><number>0</number></property>
    <property name="topMargin"><number>0</number></property>
    <property name="rightMargin"><number>0</number></property>
    <property name="bottomMargin"><number>0</number></property>
    <property name="spacing"><number>0</number></property>

    <!-- Top bar with back action -->
    <item>
     <widget class="QFrame" name="topBar">
      <property name="minimumSize"><size><width>0</width><height>52</height></size></property>
      <property name="maximumSize"><size><width>16777215</width><height>52</height></size></property>
      <layout class="QHBoxLayout" name="topBarLayout">
       <property name="leftMargin"><number>16</number></property>
       <property name="rightMargin"><number>16</number></property>
       <item>
        <widget class="QPushButton" name="backToLoginButton">
         <property name="cursor"><cursorShape>PointingHandCursor</cursorShape></property>
