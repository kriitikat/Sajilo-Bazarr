         <property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property>
        </spacer>
       </item>
      </layout>
     </widget>
    </item>

    <!-- Scrollable form body -->
    <item>
     <widget class="QScrollArea" name="scrollArea">
      <property name="widgetResizable"><bool>true</bool></property>
      <property name="frameShape"><enum>QFrame::NoFrame</enum></property>
      <widget class="QWidget" name="scrollAreaContents">
       <property name="geometry"><rect><x>0</x><y>0</y><width>460</width><height>900</height></rect></property>
       <layout class="QVBoxLayout" name="formLayout">
        <property name="leftMargin"><number>32</number></property>
        <property name="topMargin"><number>8</number></property>
        <property name="rightMargin"><number>32</number></property>
        <property name="bottomMargin"><number>24</number></property>
        <property name="spacing"><number>14</number></property>

        <item>
         <widget class="QLabel" name="titleLabel">
          <property name="text"><string>Create an Account</string></property>
          <property name="alignment"><set>Qt::AlignCenter</set></property>
         </widget>
        </item>

        <item>
         <widget class="QLabel" name="subtitleLabel">
          <property name="text"><string>Sign up to join the Sajilo Bazar team</string></property>
          <property name="alignment"><set>Qt::AlignCenter</set></property>
         </widget>
        </item>

        <!-- Section: Personal information -->
        <item>
         <widget class="QGroupBox" name="personalGroup">
          <property name="title"><string>Personal Information</string></property>
          <layout class="QVBoxLayout" name="personalGroupLayout">
           <property name="spacing"><number>10</number></property>

           <item>
            <layout class="QHBoxLayout" name="nameLayout">
             <property name="spacing"><number>10</number></property>
             <item>
              <widget class="QLineEdit" name="firstNameEdit">
               <property name="minimumSize"><size><width>0</width><height>38</height></size></property>
               <property name="placeholderText"><string>First Name</string></property>
              </widget>
             </item>
             <item>
              <widget class="QLineEdit" name="lastNameEdit">
               <property name="minimumSize"><size><width>0</width><height>38</height></size></property>
               <property name="placeholderText"><string>Last Name</string></property>
              </widget>
             </item>
            </layout>
           </item>

           <item>
            <widget class="QLabel" name="roleLabel">
             <property name="text"><string>Register as</string></property>
            </widget>
           </item>
           <item>
            <widget class="QComboBox" name="roleCombo">
             <property name="minimumSize"><size><width>0</width><height>38</height></size></property>
            </widget>
           </item>

           <item>
            <widget class="QLabel" name="usernameLabel">
             <property name="text"><string>Your Username (auto-generated)</string></property>
            </widget>
           </item>
           <item>
            <layout class="QHBoxLayout" name="usernameRow">
             <property name="spacing"><number>8</number></property>
             <item>
              <widget class="QLineEdit" name="usernameEdit">
               <property name="minimumSize"><size><width>0</width><height>38</height></size></property>
               <property name="readOnly"><bool>true</bool></property>
              </widget>
             </item>
             <item>
              <widget class="QPushButton" name="regenerateUsernameButton">
               <property name="minimumSize"><size><width>90</width><height>38</height></size></property>
               <property name="maximumSize"><size><width>90</width><height>38</height></size></property>
               <property name="cursor"><cursorShape>PointingHandCursor</cursorShape></property>
               <property name="text"><string>Regenerate</string></property>
              </widget>
             </item>
            </layout>
           </item>
           <item>
            <widget class="QLabel" name="usernameHintLabel">
             <property name="text"><string/></property>
             <property name="wordWrap"><bool>true</bool></property>
            </widget>
           </item>

          </layout>
         </widget>
        </item>

        <!-- Section: Contact and security -->
        <item>
         <widget class="QGroupBox" name="contactGroup">
          <property name="title"><string>Contact &amp;&amp; Security</string></property>
          <layout class="QVBoxLayout" name="contactGroupLayout">
           <property name="spacing"><number>6</number></property>

           <item>
            <widget class="QLineEdit" name="emailEdit">
             <property name="minimumSize"><size><width>0</width><height>38</height></size></property>
             <property name="placeholderText"><string>Email</string></property>
            </widget>
           </item>
           <item>
            <widget class="QLabel" name="emailHintLabel">
             <property name="text"><string/></property>
            </widget>
           </item>

           <item>
            <widget class="QLineEdit" name="phoneEdit">
             <property name="minimumSize"><size><width>0</width><height>38</height></size></property>
             <property name="placeholderText"><string>Phone Number</string></property>
            </widget>
           </item>
           <item>
            <widget class="QLabel" name="phoneHintLabel">
             <property name="text"><string/></property>
            </widget>
           </item>

           <item>
            <layout class="QHBoxLayout" name="passwordRow">
             <item>
              <widget class="QLineEdit" name="passwordEdit">
               <property name="minimumSize"><size><width>0</width><height>38</height></size></property>
               <property name="placeholderText"><string>Password</string></property>
               <property name="echoMode"><enum>QLineEdit::Password</enum></property>
              </widget>
             </item>
            </layout>
           </item>
           <item>
            <widget class="QProgressBar" name="passwordStrengthBar">
             <property name="minimumSize"><size><width>0</width><height>6</height></size></property>
             <property name="maximumSize"><size><width>16777215</width><height>6</height></size></property>
             <property name="minimum"><number>0</number></property>
             <property name="maximum"><number>4</number></property>
             <property name="value"><number>0</number></property>
             <property name="textVisible"><bool>false</bool></property>
            </widget>
           </item>
           <item>
            <widget class="QLabel" name="passwordHintLabel">
             <property name="text"><string>At least 6 characters</string></property>
            </widget>
           </item>

           <item>
            <widget class="QLineEdit" name="confirmPasswordEdit">
             <property name="minimumSize"><size><width>0</width><height>38</height></size></property>
