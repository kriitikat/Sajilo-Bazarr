  <property name="styleSheet">
   <string notr="true">QWidget#StaffPerform {
    background-color: #fbf3f5;
    font-family: 'Segoe UI';
}

/* ── Back to Dashboard (shared convention with category.ui) ─────────────── */
QPushButton#backToDashboardBtn {
    background-color: transparent;
    border: 1.5px solid #660033;
    border-radius: 10px;
    padding: 7px 16px;
    color: #660033;
    font-weight: bold;
    font-size: 11px;
}
QPushButton#backToDashboardBtn:hover {
    background-color: #660033;
    color: white;
}

/* ── Per-row ACTIONS button styling ───────────────────────────────────────
   Buttons in staffperform.cpp's buildActionsWidget() only set a
   QPushButton's &quot;actionRole&quot; dynamic property (disable / enable /
   expire / unexpire); all color/hover/font/radius styling lives here,
   same convention as staff.ui, so staffperform.cpp never touches
   presentation directly. */
QPushButton[actionRole=&quot;disable&quot;] {
    background-color: #d97706;
    border: none;
    border-radius: 6px;
    padding: 4px 10px;
    color: white;
    font-weight: bold;
    font-size: 11px;
}
QPushButton[actionRole=&quot;disable&quot;]:hover {
    background-color: #b45309;
}

QPushButton[actionRole=&quot;enable&quot;] {
    background-color: #16a34a;
    border: none;
    border-radius: 6px;
    padding: 4px 10px;
    color: white;
    font-weight: bold;
    font-size: 11px;
}
QPushButton[actionRole=&quot;enable&quot;]:hover {
    background-color: #15803d;
}

QPushButton[actionRole=&quot;expire&quot;] {
    background-color: #8B0000;
    border: none;
    border-radius: 6px;
    padding: 4px 10px;
    color: white;
    font-weight: bold;
    font-size: 11px;
}
QPushButton[actionRole=&quot;expire&quot;]:hover {
    background-color: #660000;
}

QPushButton[actionRole=&quot;unexpire&quot;] {
    background-color: #0891b2;
    border: none;
    border-radius: 6px;
    padding: 4px 10px;
    color: white;
    font-weight: bold;
    font-size: 11px;
}
QPushButton[actionRole=&quot;unexpire&quot;]:hover {
    background-color: #0e7490;
}</string>
